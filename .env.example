# PostgreSQL — harus sama dengan POSTGRES_PASSWORD di bawah
# Di production: ganti host menjadi "postgres" (nama service docker)
DATABASE_URL=postgres://nexone:GANTI_PASSWORD_KUAT@postgres:5432/nexone_landing?sslmode=disable

# Dipakai docker-compose untuk service postgres
POSTGRES_USER=nexone
POSTGRES_PASSWORD=GANTI_PASSWORD_KUAT

# Secret untuk sign JWT token — minimal 32 karakter acak
JWT_SECRET=GANTI_SECRET_PANJANG_DAN_ACAK

# Akun admin pertama (dibuat otomatis saat startup)
ADMIN_EMAIL=admin@nexoratech.co
ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN

# Port backend (internal, tidak perlu diekspos)
PORT=8089

# Origin yang diizinkan CORS — sesuaikan domain production
ALLOWED_ORIGINS=https://product-nexone.nexoratech.co